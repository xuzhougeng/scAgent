          "artifact_title": "PBMC old UMAP",
          "artifact_summary": "An older PBMC UMAP from the parent object.",
          "color_by": "sample",
          "legend_loc": "right",
          "point_size": 6,
          "title": "PBMC by sample"
        }
      },
      "current_job": {
        "status": "succeeded",
        "steps": [
          {
            "skill": "export_h5ad",
            "status": "succeeded",
            "summary": "Exported the subset object to pbmc3k_b_cells.h5ad and generated a file artifact.",
            "artifact_kind": "file",
            "metadata": {
              "artifact_title": "pbmc3k_b_cells.h5ad",
              "artifact_summary": "Exported h5ad file artifact for the subset object."
            }
          }
        ]
      },
      "expected": {
        "completed": true,
        "reason_should_mention": ["export", "artifact"]
      }
    },
    {
      "id": "evaluator_subset_without_plot_not_completed",
      "component": "evaluator",
      "title": "子集已生成但图还没画",
      "user_message": "把 B cells 提出来再画 UMAP",
      "current_job": {
        "status": "running_or_partial",
        "steps": [
          {
            "skill": "subset_cells",
            "status": "succeeded"
          }
        ]
      },
      "expected": {
        "completed": false
      }
    },
    {
      "id": "evaluator_subset_then_export_not_completed",
      "component": "evaluator",
      "title": "subset+export 工作流只做完子集还不算完成",
      "user_message": "把 B cells 单独拿出来然后导出成 h5ad",
      "current_job": {
        "status": "running_or_partial",
        "steps": [
          {
            "skill": "subset_cells",
            "status": "succeeded"
          }
        ]
      },
      "expected": {
        "completed": false
      }
    },
    {
      "id": "evaluator_subset_then_export_completed",
      "component": "evaluator",
      "title": "subset+export 工作流完整完成",
      "user_message": "把 B cells 单独拿出来然后导出成 h5ad",
      "current_job": {
        "status": "succeeded",
        "steps": [
          {
            "skill": "subset_cells",
            "status": "succeeded"
          },
          {
            "skill": "export_h5ad",
            "status": "succeeded",
            "summary": "Exported the subset object to pbmc3k_b_cells.h5ad and generated a file artifact.",
            "artifact_kind": "file",
            "metadata": {
              "artifact_title": "pbmc3k_b_cells.h5ad",
              "artifact_summary": "Exported h5ad file artifact for the subset object."
            }
          }
        ]
      },
      "expected": {
        "completed": true,
        "reason_should_mention": ["export", "artifact"]
      }
    },
    {
      "id": "evaluator_followup_plot_completed",
      "component": "evaluator",
      "title": "跟随式改图完成",
      "user_message": "把这个图图例放右边",
      "current_job": {
        "status": "succeeded",
        "steps": [
          {
            "skill": "plot_umap",
            "status": "succeeded",
            "metadata": {
              "legend_loc": "right",
              "color_by": "cell_type"
            },
            "artifact_kind": "plot"
          }
        ]
